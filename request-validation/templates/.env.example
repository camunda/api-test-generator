# Base URL of the Camunda Orchestration Cluster REST API.
# Defaults to http://localhost:8080 when unset.
CORE_APPLICATION_URL=http://localhost:8080

# Optional Basic-auth credentials. Leave both unset for an unauthenticated cluster.
# CAMUNDA_BASIC_AUTH_USER=demo
# CAMUNDA_BASIC_AUTH_PASSWORD=demo

# --- rbac profile only (read-side RBAC deny-tests, #359) ---
# Run with RV_PROFILE=rbac against an authorizations-enabled cluster
# (CAMUNDA_SECURITY_AUTHORIZATIONS_ENABLED=true) using the admin creds above. The
# suite global-setup provisions this zero-grant probe user; deny-tests then
# authenticate as it and expect 403. Defaults shown; override for CI.
# RBAC_DENY_PROBE_USER=rbac-deny-probe
# RBAC_DENY_PROBE_PASSWORD=rbac-deny-probe-pw
