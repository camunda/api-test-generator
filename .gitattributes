# Normalise line endings across Windows / macOS / Linux contributors.
# Without this, Windows checkouts can introduce CRLF that breaks Biome
# formatting, fails byte-reproducible generator output, and produces
# noisy diffs.

# Default: auto-detect text and normalise to LF in the repo, native on checkout.
* text=auto eol=lf

# Source code — always LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.svg       text eol=lf
*.xml       text eol=lf
*.toml      text eol=lf
*.grit      text eol=lf

# Shell scripts — must remain LF even on Windows or they fail to execute.
*.sh        text eol=lf
*.bash      text eol=lf

# Windows-only scripts — keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Lockfiles and generated manifests — LF, marked generated so GitHub
# collapses them in diffs.
package-lock.json   text eol=lf linguist-generated=true
spec/bundled/**     text eol=lf linguist-generated=true

# Fixtures consumed verbatim by the generator — LF, never auto-converted.
tests/fixtures/**   text eol=lf
**/fixtures/**.bpmn text eol=lf
**/fixtures/**.dmn  text eol=lf
**/fixtures/**.form text eol=lf

# Binary assets — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.tar       binary
*.woff      binary
*.woff2     binary
